VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
VITE_API_URL=http://localhost:3001

# Public origin of the Express API (verification links, OAuth redirect URI). Production: HTTPS API host, no trailing slash.
API_PUBLIC_URL=http://localhost:3001

# Google OAuth (Web client). Authorized redirect URI must match exactly: ${API_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend (Express)
PORT=3001
API_JWT_SECRET=<generate-with: openssl rand -base64 32>
ALLOWED_ORIGINS=http://localhost:3000
# Resend: env được ưu tiên. Hoặc lưu resend_api_key + resend_from trong Admin → Cài đặt email (app_settings).
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM=Meeting Scribe <no-reply@yourdomain.com>

# Database (Postgres)
DATABASE_URL=<your-database-url>
# DB_SSL=false  # set to 'false' to disable SSL in production (default: enabled)
# Hoặc dùng biến tách rời:
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=meeting_test
# DB_USER=<your-db-user>
# DB_PASS=<your-db-password>

# Payment Gateway (VNPay)
VNPAY_TMN_CODE=<your-vnpay-tmn-code>
VNPAY_SECURE_SECRET=<your-vnpay-secure-secret>

# Payment Gateway (MoMo)
MOMO_PARTNER_CODE=<your-momo-partner-code>
MOMO_ACCESS_KEY=<your-momo-access-key>
MOMO_SECRET_KEY=<your-momo-secret-key>

# Payment Gateway (VietQR - chuyển khoản ngân hàng)
VIETQR_BANK_BIN=<mã BIN ngân hàng, vd: 970415 cho Vietinbank>
VIETQR_ACCOUNT_NO=<số tài khoản>
VIETQR_ACCOUNT_NAME=<tên chủ tài khoản>
# Secret để xác thực webhook từ dịch vụ bridge (tùy chọn - nếu để trống thì không check)
VIETQR_WEBHOOK_SECRET=<secret-token>

# App public URL (SPA origin; required for payment return/IPN URLs and post-verify login redirect — HTTPS in production)
# Google Cloud Console → Authorized JavaScript origins may include this URL (e.g. http://localhost:3000).
APP_URL=http://localhost:3000

# Billing: credits ≈ VND; output cost = OUTPUT_USD_PER_MILLION_TOKENS (3) × this rate / 1M tokens
# BILLING_USD_TO_VND=25000
