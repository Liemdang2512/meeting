VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_API_URL=http://localhost:3001

# Backend (Express)
PORT=3001
API_JWT_SECRET=<generate-with: openssl rand -base64 32>
ALLOWED_ORIGINS=http://localhost:3000
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM=Meeting Scribe <no-reply@yourdomain.com>

# Database (Postgres)
DATABASE_URL=<your-database-url>
# DB_SSL=false  # set to 'false' to disable SSL in production (default: enabled)
# Hoặc dùng biến tách rời:
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=meeting_test
# DB_USER=<your-db-user>
# DB_PASS=<your-db-password>

# Payment Gateway (VNPay)
VNPAY_TMN_CODE=<your-vnpay-tmn-code>
VNPAY_SECURE_SECRET=<your-vnpay-secure-secret>

# Payment Gateway (MoMo)
MOMO_PARTNER_CODE=<your-momo-partner-code>
MOMO_ACCESS_KEY=<your-momo-access-key>
MOMO_SECRET_KEY=<your-momo-secret-key>

# App public URL (required for payment return/IPN URLs — must be HTTPS in production)
APP_URL=http://localhost:3000
